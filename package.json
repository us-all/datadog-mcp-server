{
  "name": "@us-all/datadog-mcp",
  "version": "1.9.2",
  "description": "Datadog MCP server - 158 tools for metrics, monitors, logs, APM, RUM, incidents, CI/CD, status pages, fleet automation, and more",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "datadog-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/us-all/datadog-mcp-server.git"
  },
  "homepage": "https://github.com/us-all/datadog-mcp-server#readme",
  "bugs": "https://github.com/us-all/datadog-mcp-server/issues",
  "keywords": [
    "mcp",
    "datadog",
    "monitoring",
    "observability",
    "apm",
    "rum",
    "model-context-protocol"
  ],
  "author": "us-all",
  "license": "MIT",
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.14"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "presmoke": "pnpm run build",
    "smoke": "node scripts/smoke-test.mjs",
    "pretoken-stats": "pnpm run build",
    "token-stats": "node scripts/measure-tokens.mjs"
  },
  "dependencies": {
    "@datadog/datadog-api-client": "^1.56.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "dd-trace": "^5.92.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
